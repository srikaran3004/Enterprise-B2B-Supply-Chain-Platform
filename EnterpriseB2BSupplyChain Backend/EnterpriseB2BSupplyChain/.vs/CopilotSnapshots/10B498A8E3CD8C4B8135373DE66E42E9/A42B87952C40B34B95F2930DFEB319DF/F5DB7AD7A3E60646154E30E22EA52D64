using MediatR;
using SupplyChain.Identity.Application.Abstractions;
using SupplyChain.Identity.Domain.Entities;

namespace SupplyChain.Identity.Application.Commands.RegisterDealer;

public class RegisterDealerCommandHandler : IRequestHandler<RegisterDealerCommand, Guid>
{
    private readonly IUserRepository _userRepository;
    private readonly IPasswordHasher _passwordHasher;

    public RegisterDealerCommandHandler(IUserRepository userRepository, IPasswordHasher passwordHasher)
    {
        _userRepository = userRepository;
        _passwordHasher = passwordHasher;
    }

    public async Task<Guid> Handle(RegisterDealerCommand command, CancellationToken ct)
    {
        // Check uniqueness
        if (await _userRepository.EmailExistsAsync(command.Email, ct))
            throw new InvalidOperationException($"Email '{command.Email}' is already registered.");

        if (await _userRepository.GstNumberExistsAsync(command.GstNumber, ct))
            throw new InvalidOperationException($"GST number '{command.GstNumber}' is already registered.");

        // Create User aggregate
        var passwordHash = _passwordHasher.Hash(command.Password);
        var user = User.CreateDealer(command.Email, passwordHash, command.FullName, command.PhoneNumber);

        // Create DealerProfile
        var profile = DealerProfile.Create(
            userId: user.UserId,
            businessName: command.BusinessName,
            gstNumber: command.GstNumber,
            addressLine1: command.AddressLine1,
            city: command.City,
            state: command.State,
            pinCode: command.PinCode,
            isInterstate: command.IsInterstate,
            tradeLicenseNumber: command.TradeLicenseNumber
        );

        await _userRepository.AddAsync(user, ct);
        await _userRepository.AddDealerProfileAsync(profile, ct);
        await _userRepository.SaveChangesAsync(ct);

        // Note: DomainEvents on the user will be published after save
        // (we will wire this up in Infrastructure via EF Core interceptors later)

        return user.UserId;
    }
}