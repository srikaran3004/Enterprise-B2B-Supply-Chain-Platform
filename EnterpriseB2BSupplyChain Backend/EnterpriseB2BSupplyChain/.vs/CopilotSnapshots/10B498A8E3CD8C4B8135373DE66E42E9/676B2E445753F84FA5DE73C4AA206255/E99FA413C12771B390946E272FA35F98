using MediatR;
using Microsoft.EntityFrameworkCore;
using SupplyChain.Catalog.Application.DTOs;
using SupplyChain.Catalog.Domain.Entities;
using SupplyChain.Catalog.Infrastructure.Persistence;

namespace SupplyChain.Catalog.Application.Queries.GetFavorites;

public class GetFavoritesQueryHandler : IRequestHandler<GetFavoritesQuery, List<ProductDto>>
{
    private readonly CatalogDbContext _context;

    public GetFavoritesQueryHandler(CatalogDbContext context)
    {
        _context = context;
    }

    public async Task<List<ProductDto>> Handle(GetFavoritesQuery query, CancellationToken ct)
    {
        var favorites = await _context.Set<FavoriteProduct>()
            .Where(f => f.DealerId == query.DealerId)
            .Include(f => f.Product)
            .ThenInclude(p => p!.Category)
            .Select(f => f.Product!)
            .ToListAsync(ct);

        return favorites.Select(p => new ProductDto(
            p.ProductId,
            p.SKU,
            p.Name,
            p.Description,
            p.Brand,
            p.CategoryId,
            p.Category?.Name,
            p.UnitPrice,
            p.MinOrderQuantity,
            p.AvailableStock,
            p.IsInStock,
            p.IsActive,
            p.ImageUrl,
            p.CreatedAt
        )).ToList();
    }
}
