using MediatR;
using SupplyChain.Catalog.Application.Abstractions;
using SupplyChain.Catalog.Domain.Entities;

namespace SupplyChain.Catalog.Application.Commands.ToggleFavorite;

public class ToggleFavoriteCommandHandler : IRequestHandler<ToggleFavoriteCommand, bool>
{
    private readonly IProductRepository _productRepository;

    public ToggleFavoriteCommandHandler(IProductRepository productRepository)
    {
        _productRepository = productRepository;
    }

    public async Task<bool> Handle(ToggleFavoriteCommand command, CancellationToken ct)
    {
        var existing = await _productRepository.GetFavoriteAsync(command.DealerId, command.ProductId, ct);

        if (existing != null)
        {
            // Remove from favorites
            await _productRepository.RemoveFavoriteAsync(existing, ct);
            await _productRepository.SaveChangesAsync(ct);
            return false; // Not favorited anymore
        }
        else
        {
            // Add to favorites
            var favorite = FavoriteProduct.Create(command.DealerId, command.ProductId);
            await _productRepository.AddFavoriteAsync(favorite, ct);
            await _productRepository.SaveChangesAsync(ct);
            return true; // Now favorited
        }
    }
}
