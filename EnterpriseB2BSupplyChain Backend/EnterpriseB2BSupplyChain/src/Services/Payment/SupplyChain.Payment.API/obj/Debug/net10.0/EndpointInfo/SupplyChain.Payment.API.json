  "components": {
    "schemas": {
      "ConfirmRazorpayPaymentRequest": {
        "required": [
          "razorpayOrderId",
          "razorpayPaymentId",
          "razorpaySignature"
        ],
        "type": "object",
        "properties": {
          "razorpayOrderId": {
            "type": "string"
          },
          "razorpayPaymentId": {
            "type": "string"
          },
          "razorpaySignature": {
            "type": "string"
          },
          "orderId": {
            "type": [
              "null",
              "string"
            ],
            "format": "uuid"
          },
          "amount": {
            "pattern": "^-?(?:0|[1-9]\\d*)(?:\\.\\d+)?$",
            "type": [
              "null",
              "number",
              "string"
            ],
            "format": "double"
          }
        }
      },
      "CreateRazorpayOrderRequest": {
        "required": [
          "amount",
          "receiptId"
        ],
        "type": "object",
        "properties": {
          "amount": {
            "pattern": "^-?(?:0|[1-9]\\d*)(?:\\.\\d+)?$",
            "type": [
              "number",
              "string"
            ],
            "format": "double"
          },
          "receiptId": {
            "type": "string"
          }
        }
      },
      "GenerateInvoiceCommand": {
        "required": [
          "orderId",
          "dealerId",
          "totalAmount",
          "paymentMode",
          "isInterstate",
          "lines"
        ],
        "type": "object",
        "properties": {
          "orderId": {
            "type": "string",
            "format": "uuid"
          },
          "dealerId": {
            "type": "string",
            "format": "uuid"
          },
          "totalAmount": {
            "pattern": "^-?(?:0|[1-9]\\d*)(?:\\.\\d+)?$",
            "type": [
              "number",
              "string"
            ],
            "format": "double"
          },
          "paymentMode": {
            "type": "string"
          },
          "isInterstate": {
            "type": "boolean"
          },
          "lines": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/InvoiceLineRequest"
            }
          }
        }
      },
      "InvoiceLineRequest": {
        "required": [
          "productId",
          "productName",
          "sku",
          "quantity",
          "unitPrice"
        ],
        "type": "object",
        "properties": {
          "productId": {
            "type": "string",
            "format": "uuid"
          },
          "productName": {
            "type": "string"
          },
          "sku": {
            "type": "string"
          },
          "quantity": {
            "pattern": "^-?(?:0|[1-9]\\d*)$",
            "type": [
              "integer",
              "string"
            ],
            "format": "int32"
          },
          "unitPrice": {
            "pattern": "^-?(?:0|[1-9]\\d*)(?:\\.\\d+)?$",
            "type": [
              "number",
              "string"
            ],
            "format": "double"
          }
        }
      },
      "SimulateCaptureRequest": {
        "required": [
          "razorpayOrderId"
        ],
        "type": "object",
        "properties": {
          "razorpayOrderId": {
            "type": "string"
          },
          "orderId": {
            "type": [
              "null",
              "string"
            ],
            "format": "uuid"
          },
          "amount": {
            "pattern": "^-?(?:0|[1-9]\\d*)(?:\\.\\d+)?$",
            "type": [
              "null",
              "number",
              "string"
            ],
            "format": "double"
          }
        }
      },
      "UpdateLimitRequest": {
        "required": [
          "newLimit"
        ],
        "type": "object",
        "properties": {
          "newLimit": {
            "pattern": "^-?(?:0|[1-9]\\d*)(?:\\.\\d+)?$",
            "type": [
              "number",
              "string"
            ],
            "format": "double"
          }
        }
      }
    }
  },
  "tags": [
