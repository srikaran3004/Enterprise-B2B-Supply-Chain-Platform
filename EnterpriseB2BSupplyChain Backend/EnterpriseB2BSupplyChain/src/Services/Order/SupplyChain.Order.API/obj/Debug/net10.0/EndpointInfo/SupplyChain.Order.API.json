  },
  "components": {
    "schemas": {
      "CancelRequest": {
        "required": [
          "reason"
        ],
        "type": "object",
        "properties": {
          "reason": {
            "type": "string"
          }
        }
      },
      "OrderLineRequest": {
        "required": [
          "productId",
          "productName",
          "sku",
          "unitPrice",
          "quantity"
        ],
        "type": "object",
        "properties": {
          "productId": {
            "type": "string",
            "format": "uuid"
          },
          "productName": {
            "type": "string"
          },
          "sku": {
            "type": "string"
          },
          "unitPrice": {
            "pattern": "^-?(?:0|[1-9]\\d*)(?:\\.\\d+)?$",
            "type": [
              "number",
              "string"
            ],
            "format": "double"
          },
          "quantity": {
            "pattern": "^-?(?:0|[1-9]\\d*)$",
            "type": [
              "integer",
              "string"
            ],
            "format": "int32"
          }
        }
      },
      "PlaceOrderCommand": {
        "required": [
          "dealerId",
          "lines",
          "paymentMode",
          "notes"
        ],
        "type": "object",
        "properties": {
          "dealerId": {
            "type": "string",
            "format": "uuid"
          },
          "lines": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/OrderLineRequest"
            }
          },
          "paymentMode": {
            "type": "string"
          },
          "notes": {
            "type": [
              "null",
              "string"
            ]
          },
          "shippingAddressId": {
            "type": [
              "null",
              "string"
            ],
            "format": "uuid"
          },
          "dealerEmail": {
            "type": [
              "null",
              "string"
            ]
          },
          "dealerName": {
            "type": [
              "null",
              "string"
            ]
          }
        }
      },
      "RaiseReturnRequest": {
        "required": [
          "reason"
        ],
        "type": "object",
        "properties": {
          "reason": {
            "type": "string"
          },
          "photoUrl": {
            "type": [
              "null",
              "string"
            ]
          }
        }
      },
      "ReturnActionRequest": {
        "required": [
          "adminNotes"
        ],
        "type": "object",
        "properties": {
          "adminNotes": {
            "type": [
              "null",
              "string"
            ]
          }
        }
      }
    }
  },
  "tags": [
    {
      "name": "InternalOrders"
    },
    {
      "name": "Orders"
    },
    {
      "name": "Returns"
    }
  ]
