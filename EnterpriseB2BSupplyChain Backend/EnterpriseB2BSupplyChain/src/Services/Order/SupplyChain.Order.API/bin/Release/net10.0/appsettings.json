{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": "Server=.\\SQLEXPRESS;Database=HUL_OrderDb;Trusted_Connection=True;TrustServerCertificate=True;MultipleActiveResultSets=True;"
  },
  "Jwt": {
    "Secret": "UniSupply@SecretKey#2025$Platform!Enterprise",
    "Issuer": "UniSupplyPlatform",
    "Audience": "UniSupplyAPI",
    "ExpiryMinutes": "60"
  },
  "RabbitMQ": {
    "Host":     "localhost",
    "Username": "guest",
    "Password": "guest"
  },
  "ServiceUrls": {
    "PaymentService": "http://localhost:5010",
    "IdentityService": "http://localhost:5002",
    "CatalogService": "http://localhost:5004"
  },
  "Observability": {
    "LogsRoot": "logs",
    "RetentionDays": 14,
    "EnableFileLogging": true
  },
  "Cleanup": {
    "OutboxRetentionDays": 14
  }
}
