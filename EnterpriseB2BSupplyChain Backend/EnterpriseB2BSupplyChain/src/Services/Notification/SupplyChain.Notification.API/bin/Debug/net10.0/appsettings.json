{
  "Logging": {
    "LogLevel": {
      "Default": "Information"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": "Server=.\\SQLEXPRESS;Database=HUL_NotificationDb;Trusted_Connection=True;TrustServerCertificate=True;MultipleActiveResultSets=True;"
  },
  "Jwt": {
    "Secret": "UniSupply@SecretKey#2025$Platform!Enterprise",
    "Issuer": "UniSupplyPlatform",
    "Audience": "UniSupplyAPI",
    "ExpiryMinutes": "60"
  },
  "Email": {
    "SmtpHost": "smtp.gmail.com",
    "SmtpPort": "587",
    "Username": "your-email@gmail.com",
    "Password": "your-app-password",
    "FromAddress": "noreply@unidistrib.com"
  },
  "RabbitMQ": {
    "Host": "localhost",
    "Username": "guest",
    "Password": "guest",
    "Exchange": "supplychain.domain.events",
    "Queue": "notification.email.queue",
    "RoutingKey": "#",
    "DeadLetterExchange": "supplychain.domain.events.dead",
    "DeadLetterQueue": "notification.email.queue.dead",
    "DeadLetterRoutingKey": "notification.email.queue.dead",
    "MaxRetries": 5
  },
  "Observability": {
    "LogsRoot": "logs",
    "RetentionDays": 14,
    "EnableFileLogging": true
  },
  "Cleanup": {
    "NotificationLogRetentionDays": 30
  }
}
