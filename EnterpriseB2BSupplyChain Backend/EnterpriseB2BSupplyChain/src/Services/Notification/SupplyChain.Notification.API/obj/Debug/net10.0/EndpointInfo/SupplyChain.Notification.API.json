{
  "openapi": "3.1.1",
  "info": {
    "title": "Notification Service",
    "version": "v1"
  },
  "servers": [
    {
      "url": "https://localhost:7202"
    },
    {
      "url": "http://localhost:5012"
    }
  ],
  "paths": {
    "/api/notifications/inbox": {
      "get": {
        "tags": [
          "Notification"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/api/notifications/inbox/unread-count": {
      "get": {
        "tags": [
          "Notification"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/api/notifications/inbox/{notificationId}/read": {
      "put": {
        "tags": [
          "Notification"
        ],
        "parameters": [
          {
            "name": "notificationId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/api/notifications/inbox/read-all": {
      "put": {
        "tags": [
          "Notification"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/api/notifications/templates": {
      "get": {
        "tags": [
          "Notifications"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/api/notifications/templates/{templateId}": {
      "put": {
        "tags": [
          "Notifications"
        ],
        "parameters": [
          {
            "name": "templateId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/UpdateTemplateRequest"
              }
            },
            "text/json": {
              "schema": {
                "$ref": "#/components/schemas/UpdateTemplateRequest"
              }
            },
            "application/*+json": {
              "schema": {
                "$ref": "#/components/schemas/UpdateTemplateRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "UpdateTemplateRequest": {
        "required": [
          "subject",
          "htmlBody"
        ],
        "type": "object",
        "properties": {
          "subject": {
            "type": "string"
          },
          "htmlBody": {
            "type": "string"
          }
        }
      }
    }
  },
  "tags": [
    {
      "name": "Notification"
    },
    {
      "name": "Notifications"
    }
  ]
}