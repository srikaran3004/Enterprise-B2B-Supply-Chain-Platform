{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": "Server=.\\SQLEXPRESS;Database=HUL_LogisticsDb;Trusted_Connection=True;TrustServerCertificate=True;MultipleActiveResultSets=True;"
  },
  "Jwt": {
    "Secret": "UniSupply@SecretKey#2025$Platform!Enterprise",
    "Issuer": "UniSupplyPlatform",
    "Audience": "UniSupplyAPI",
    "ExpiryMinutes": "60"
  },
  "Redis": { "ConnectionString": "localhost:6379" },
  "RabbitMQ": {
    "Host": "localhost",
    "Username": "guest",
    "Password": "guest",
    "Exchange": "supplychain.domain.events",
    "OrderReadyQueue": "logistics.order-ready.queue",
    "OrderReadyRoutingKey": "order.readyfordispatch",
    "DeadLetterExchange": "supplychain.domain.events.dead",
    "DeadLetterQueue": "logistics.order-ready.queue.dead",
    "DeadLetterRoutingKey": "logistics.order-ready.queue.dead",
    "MaxRetries": 5
  },
  "ServiceUrls": {
    "IdentityService": "http://localhost:5002",
    "OrderService": "http://localhost:5006"
  },
  "Logistics": {
    "DefaultSlaHours": 72
  },
  "Observability": {
    "LogsRoot": "logs",
    "RetentionDays": 14,
    "EnableFileLogging": true
  }
}
