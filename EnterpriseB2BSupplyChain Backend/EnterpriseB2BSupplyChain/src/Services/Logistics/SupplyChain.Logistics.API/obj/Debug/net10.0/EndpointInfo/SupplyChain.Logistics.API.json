              }
            },
            "text/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateShipmentCommand"
              }
            },
            "application/*+json": {
              "schema": {
                "$ref": "#/components/schemas/CreateShipmentCommand"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      },
      "get": {
        "tags": [
          "Logistics"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/api/logistics/shipments/pending": {
      "get": {
        "tags": [
