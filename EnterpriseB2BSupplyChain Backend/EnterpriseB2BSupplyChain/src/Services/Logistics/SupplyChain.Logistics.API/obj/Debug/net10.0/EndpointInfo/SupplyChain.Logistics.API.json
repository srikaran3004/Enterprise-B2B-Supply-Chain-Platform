  },
  "components": {
    "schemas": {
      "AssignAgentCommand": {
        "required": [
          "orderId",
          "agentId",
          "vehicleId"
        ],
        "type": "object",
        "properties": {
          "orderId": {
            "type": "string",
            "format": "uuid"
          },
          "agentId": {
            "type": "string",
            "format": "uuid"
          },
          "vehicleId": {
            "type": "string",
            "format": "uuid"
          },
          "slaDeadlineUtc": {
            "type": [
              "null",
              "string"
            ],
            "format": "date-time"
          }
        }
      },
      "CreateAgentCommand": {
        "required": [
          "userId",
          "fullName",
          "phone",
          "licenseNumber",
          "serviceRegion"
        ],
        "type": "object",
        "properties": {
          "userId": {
            "type": "string",
            "format": "uuid"
          },
          "fullName": {
            "type": "string"
          },
          "phone": {
            "type": "string"
          },
          "licenseNumber": {
            "type": [
              "null",
              "string"
            ]
          },
          "serviceRegion": {
            "type": [
              "null",
              "string"
            ]
          }
        }
      },
      "CreateShipmentCommand": {
        "required": [
          "orderId",
          "slaDeadlineUtc"
        ],
        "type": "object",
        "properties": {
          "orderId": {
            "type": "string",
            "format": "uuid"
          },
          "slaDeadlineUtc": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "CreateVehicleCommand": {
        "required": [
          "registrationNo",
          "vehicleType",
          "capacityKg"
        ],
        "type": "object",
        "properties": {
          "registrationNo": {
            "type": "string"
          },
          "vehicleType": {
            "type": "string"
          },
          "capacityKg": {
            "pattern": "^-?(?:0|[1-9]\\d*)(?:\\.\\d+)?$",
            "type": [
              "null",
              "number",
              "string"
            ],
            "format": "double"
          }
        }
      },
      "RateShipmentRequest": {
        "required": [
          "rating"
        ],
        "type": "object",
        "properties": {
          "rating": {
            "pattern": "^-?(?:0|[1-9]\\d*)$",
            "type": [
              "integer",
              "string"
            ],
            "format": "int32"
          },
          "feedback": {
            "type": [
              "null",
              "string"
            ]
          }
        }
      },
      "UpdateStatusRequest": {
        "required": [
          "status"
        ],
        "type": "object",
        "properties": {
          "status": {
            "type": "string"
          },
          "latitude": {
            "pattern": "^-?(?:0|[1-9]\\d*)(?:\\.\\d+)?$",
            "type": [
              "null",
              "number",
              "string"
            ],
            "format": "double"
          },
          "longitude": {
            "pattern": "^-?(?:0|[1-9]\\d*)(?:\\.\\d+)?$",
            "type": [
              "null",
              "number",
              "string"
            ],
            "format": "double"
          },
          "notes": {
            "type": [
              "null",
              "string"
            ]
          },
          "place": {
            "type": [
              "null",
              "string"
            ]
          }
        }
      }
    }
  },
  "tags": [
    {
      "name": "Logistics"
    }
  ]
}